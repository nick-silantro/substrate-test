def cmd_entity_create(rest: list[str]) -> None:
    # Resolve type alias for --type flag
    new_rest = list(rest)
    for i, arg in enumerate(new_rest):
        if arg == "--type" and i + 1 < len(new_rest):
            aliases = _load_overlay().get("aliases", {})
            new_rest[i + 1] = _resolve_type_alias(new_rest[i + 1], aliases)
            break
    run("create-entity.py", new_rest)


