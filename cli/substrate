        print(f"substrate schema unhide: unknown kind '{kind}' — must be type, attribute, or relationship", file=sys.stderr)
        sys.exit(1)

    overlay = _load_overlay()
    hidden = overlay.get("hidden", {})
    if not isinstance(hidden, dict):
        hidden = {}

    kind_key = kind + "s"
    kind_list = hidden.get(kind_key, [])
    if not isinstance(kind_list, list):
        kind_list = []

    if name not in kind_list:
        print(json.dumps({"error": f"'{name}' is not hidden."}))
        sys.exit(1)

    kind_list.remove(name)
    hidden[kind_key] = kind_list
    overlay["hidden"] = hidden
    _save_overlay(overlay)

    print(json.dumps({"status": "ok", "kind": kind, "name": name, "hidden": False}))


