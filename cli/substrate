def _check_for_updates_xml(cmd_path: Path, workspace: Path, logs_dir: Path) -> str:
    return f"""<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Substrate update checker — runs every 30 minutes</Description>
  </RegistrationInfo>
