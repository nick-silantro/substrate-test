def _link_skills(engine_skills: Path, instance_skills: Path) -> None:
    """Link instance .claude/skills/ to the engine skills directory.

    Uses a symlink on macOS/Linux and a directory junction on Windows (no admin
    or Developer Mode required). Replaces legacy copied directories transparently.
    """
    if not engine_skills.exists():
        return
    if instance_skills.is_symlink():
        if instance_skills.resolve() == engine_skills.resolve():
            return  # already correct
        instance_skills.unlink()
    elif instance_skills.exists():
        import shutil as _sh
        _sh.rmtree(instance_skills)
    instance_skills.parent.mkdir(parents=True, exist_ok=True)
    if sys.platform == "win32":
        subprocess.run(
            ["cmd", "/c", "mklink", "/J", str(instance_skills), str(engine_skills)],
            check=True, capture_output=True,
        )
    else:
        instance_skills.symlink_to(engine_skills)


def cmd_init(rest: list[str]) -> None:
    import textwrap

    p = argparse.ArgumentParser(prog="substrate init")
    p.add_argument("path", nargs="?", default=str(Path("~/substrate").expanduser()),
                   help="Instance directory to create (default: ~/substrate)")
    p.add_argument("--reinit", action="store_true",
                   help="Refresh CLAUDE.md and rebuild index on an existing instance")
    p.add_argument("--force", action="store_true",
                   help="Create instance in a non-empty non-Substrate directory")
    p.add_argument("--no-services", action="store_true",
                   help="Skip background service installation")
    args = p.parse_args(rest)

    target = Path(args.path).expanduser().resolve()

    if target.exists() and _is_substrate_instance(target) and not args.reinit:
        print(f"substrate init: '{target}' is already a Substrate instance.")
        print(f"  To use it:        export SUBSTRATE_PATH={target}")
        print(f"  To refresh it:    substrate init {target} --reinit")
        sys.exit(1)

    if target.exists() and not _is_substrate_instance(target) and any(target.iterdir()) and not args.force:
        print(f"substrate init: '{target}' exists and is not empty.")
        print("  If it's a different project, choose a different path.")
        print(f"  To force creation here: substrate init {target} --force")
        sys.exit(1)

    ep = engine_path()

    # Create instance directory structure
    (target / "entities").mkdir(parents=True, exist_ok=True)
    (target / "assets").mkdir(exist_ok=True)
    (target / "staging").mkdir(exist_ok=True)
    (target / "builds").mkdir(exist_ok=True)
    (target / "_system" / "index").mkdir(parents=True, exist_ok=True)  # ephemeral db lives here

    # Write overlay.yaml inside _system/ (only if it doesn't exist — don't clobber customizations)
    overlay = target / "_system" / "overlay.yaml"
    if not overlay.exists():
        # Pin the engine path explicitly so this workspace always uses the installed engine,
        # even if SUBSTRATE_ENGINE_PATH is set globally (e.g. to a dev checkout).
        installed_engine = Path("~/.substrate/engine").expanduser()
        import uuid as _uuid
        _workspace_id = str(_uuid.uuid4())
        overlay.write_text(textwrap.dedent(f"""\
            # Substrate workspace overlay
            # Custom types, attributes, and relationships live in _system/schema-user/
            # Use: substrate schema add type/attribute/relationship/grouping

            # Engine path — pinned at init to the installed engine.
            # Override if you want this workspace to use a different engine checkout.
            engine: {installed_engine}

            # Unique identifier for this workspace (used for metrics).
            workspace_id: {_workspace_id}

            # Rename schema elements for display and CLI input in this workspace.
            # Use: substrate schema alias type|attribute|relationship CANONICAL ALIAS
            aliases:
              types: {{}}
              attributes: {{}}
              relationships: {{}}

            # Suppress schema elements from listings and pickers.
            # Use: substrate schema hide type|attribute|relationship NAME
            hidden:
              types: []
              attributes: []
              relationships: []
        """))

    # Link skills from engine into instance
    _link_skills(ep / "_system" / "skills", target / ".claude" / "skills")

    # Symlink CLAUDE.md to engine so updates propagate automatically.
    # Windows falls back to a copy — file symlinks require Developer Mode there.
    claude_md_src = ep / "CLAUDE.md"
    dest_claude = target / "CLAUDE.md"
    if dest_claude.is_symlink() or dest_claude.exists():
        dest_claude.unlink()
    if claude_md_src.exists():
        if sys.platform == "win32":
            dest_claude.write_text(claude_md_src.read_text())
        else:
            dest_claude.symlink_to(claude_md_src)
    else:
        (target / "CLAUDE.md").write_text(textwrap.dedent("""\
            # Substrate

            Run the following at the start of every session to get your orientation:

            ```bash
            substrate context agent-orientation
            ```
        """))

    # Bootstrap the SQLite index
    env = {**os.environ, "SUBSTRATE_PATH": str(target)}
    s = script("migrate-to-sqlite.py")
    if s.exists():
        subprocess.run(["python3", str(s)], env=env, check=False)

    # Stamp the migration log — mark all current migrations as already applied.
    # Fresh installs don't need to run migrations; this ensures the updater only
    # runs migrations released AFTER this workspace was created.
    if not args.reinit:
        import json as _json
        migrations_dir = ep / "_system" / "migrations"
        applied_log = target / "_system" / "migrations-applied.json"
        if migrations_dir.exists() and not applied_log.exists():
            applied = sorted(p.name for p in migrations_dir.glob("*.py") if p.stem[0].isdigit())
            applied_log.parent.mkdir(parents=True, exist_ok=True)
            applied_log.write_text(_json.dumps(applied, indent=2), encoding="utf-8")

    if args.reinit:
        print(f"Instance refreshed at {target}")
    else:
        print(f"Instance created at {target}")
        try:
            import yaml as _yaml
            _machine_id, _is_new_machine = _ensure_machine_id()
            _ws_data = _yaml.safe_load(overlay.read_text()) or {}
            _workspace_id = _ws_data.get("workspace_id")
            _version = (ep / "VERSION").read_text().strip() if (ep / "VERSION").exists() else None
            _platform = {"darwin": "darwin", "linux": "linux", "win32": "win32"}.get(sys.platform, sys.platform)
            if _is_new_machine:
                _fire_metrics_event("machine_install", _machine_id, version=_version, platform=_platform)
            _fire_metrics_event("workspace_init", _machine_id,
                                workspace_id=_workspace_id, version=_version, platform=_platform)
        except Exception:
            pass

    if not args.no_services:
        print("\nInstalling background services...")
        _install_services(target, ep, reinstall=args.reinit)
        _setup_venv(target)

    # Set up semantic search (venv + fastembed + model). Model is cached at
    # ~/.substrate/model-cache/ so this is only slow on the very first install.
    setup_search = ep / "_system" / "scripts" / "setup-search.py"
    if setup_search.exists():
        print("\nSetting up semantic search...")
        result = subprocess.run(
            [sys.executable, str(setup_search)],
            env={**os.environ, "SUBSTRATE_PATH": str(target), "SUBSTRATE_ENGINE_PATH": str(ep)},
        )
        if result.returncode != 0:
            print("  Warning: search setup failed — semantic search will not be available.")
            print("  Run 'substrate search setup' manually when you have a network connection.")

    # Run update check once immediately so pending-updates.md is ready
    # before the first session, rather than waiting for the 30-minute timer.
    check_script = ep / "_system" / "scripts" / "check-for-updates.py"
    if check_script.exists():
        subprocess.run(
            [sys.executable, str(check_script)],
            env={**os.environ, "SUBSTRATE_PATH": str(target), "SUBSTRATE_ENGINE_PATH": str(ep)},
            capture_output=True,
        )

    print()
    print("Next steps:")
    print(f"  export SUBSTRATE_PATH={target}")
    print(f"  cd {target}")
    print("  substrate query stats")




def cmd_start(rest: list[str]) -> None:
    """
    Start Surface (and optionally Relay) against this instance.

    Usage:
      substrate start                            # Surface on port 3002
      substrate start relay                      # Relay on port 3001
      substrate start surface relay              # both on default ports
      substrate start surface relay --surface-port 3010 --relay-port 3011

    Env overrides:
      PORT                     Override port (single-component start only)
      SUBSTRATE_AUTH_PASSWORD  Set UI password (skip for local dev)
    """
    p = argparse.ArgumentParser(prog="substrate start", add_help=False)
    p.add_argument("components", nargs="*")
    p.add_argument("--surface-port", default=None)
    p.add_argument("--relay-port", default=None)
    p.add_argument("-h", "--help", action="store_true")
    args = p.parse_args(rest)

    if args.help:
        print("Usage: substrate start [surface] [relay] [--surface-port N] [--relay-port N]")
        print("  Starts Surface (port 3002) and Relay (port 3001) by default.")
        print("  Use --surface-port / --relay-port to run on alternate ports.")
        print("  Env: PORT (single component only), SUBSTRATE_AUTH_PASSWORD")
        sys.exit(0)

    ep = engine_path()
    ip = instance_path()

    web_dir = ep / "web"
    if not web_dir.exists():
        print("Error: web/ not found in engine — run 'substrate update'.", file=sys.stderr)
        sys.exit(1)

    components = args.components if args.components else ["surface", "relay"]
    default_ports = {"surface": "3002", "relay": "3001"}
    port_overrides = {"surface": args.surface_port, "relay": args.relay_port}

    procs: list[tuple[str, "subprocess.Popen[bytes]"]] = []

    for component in components:
        comp_dir = web_dir / component
        if not comp_dir.exists():
            print(f"Error: web/{component} not found in engine.", file=sys.stderr)
            sys.exit(1)

        node_modules = comp_dir / "node_modules"
        if not node_modules.exists():
            print(f"Installing {component} dependencies (first run)...")
            result = subprocess.run(["npm", "install", "--silent"], cwd=comp_dir)
            if result.returncode != 0:
                print(f"Error: npm install failed for {component}.", file=sys.stderr)
                sys.exit(1)

        dist_dir = comp_dir / "dist"
        if not dist_dir.exists():
            print(f"Building {component} (first run)...")
            result = subprocess.run(["npm", "run", "build"], cwd=comp_dir)
            if result.returncode != 0:
                print(f"Error: build failed for {component}.", file=sys.stderr)
                sys.exit(1)

        tsx = comp_dir / "node_modules" / ".bin" / "tsx"
        if not tsx.exists():
            print(f"Error: tsx not found in {comp_dir}/node_modules/.bin/", file=sys.stderr)
            sys.exit(1)

        if port_overrides.get(component):
            port = port_overrides[component]
        elif len(components) == 1:
            port = os.environ.get("PORT") or default_ports.get(component, "3000")
        else:
            port = default_ports.get(component, "3000")

        actual_port, remapped = _find_free_port(int(port))
        if remapped:
            print(f"  ⚠  Port {port} in use — using {actual_port} instead.")
        port = str(actual_port)

        env = {
            **os.environ,
            "SUBSTRATE_DIR": str(ip),
            "SUBSTRATE_ENGINE_PATH": str(ep),
            "PORT": port,
            "CLAUDE_CODE_FORK_SUBAGENT": "1",
        }

        # Pass Claude auth token through if available
        token = os.environ.get("CLAUDE_CODE_OAUTH_TOKEN") or _read_claude_oauth_token()
        if token:
            env["CLAUDE_CODE_OAUTH_TOKEN"] = token
        else:
            print(f"  ⚠  CLAUDE_CODE_OAUTH_TOKEN not set — Relay chat won't work.")
            print(f"     Run 'substrate auth' to authorize, then retry.")

        proc = subprocess.Popen([str(tsx), "server/index.ts"], cwd=comp_dir, env=env)
        procs.append((component, proc))
        print(f"  ✓ {component} → http://localhost:{port}")

    if not procs:
        sys.exit(0)

    print()
    print("Press Ctrl+C to stop.")

    import signal

    def _shutdown(sig, frame):
        print("\nStopping...")
        for _, p in procs:
            p.terminate()
        for _, p in procs:
            try:
                p.wait(timeout=5)
            except Exception:
                p.kill()
        sys.exit(0)

    signal.signal(signal.SIGINT, _shutdown)
    signal.signal(signal.SIGTERM, _shutdown)

    # Wait for all processes; if any exits unexpectedly, stop the rest
    while True:
        for name, p in procs:
            if p.poll() is not None:
                print(f"\n{name} exited (code {p.returncode}).")
                _shutdown(None, None)
        import time
        time.sleep(0.5)


def cmd_auth(rest: list[str]) -> None:
    """
    Authorize Substrate to use your Claude Pro or Max subscription.

    Usage:
      substrate auth           Check status; launch OAuth flow if not authorized
      substrate auth status    Print auth status without prompting
      substrate auth login     Force a new OAuth login even if already authorized
    """
    p = argparse.ArgumentParser(prog="substrate auth", add_help=False)
    p.add_argument("subcommand", nargs="?", default=None, choices=["status", "login"])
    p.add_argument("-h", "--help", action="store_true")
    args = p.parse_args(rest)

    if args.help:
        print("Usage: substrate auth [status|login]")
        sys.exit(0)

    existing = _read_claude_oauth_token()

    if args.subcommand == "status":
        if existing:
            print(f"✓ Authorized (token: {existing[:20]}...)")
        else:
            print("✗ Not authorized. Run 'substrate auth' to authorize.")
        return

    if args.subcommand == "login" or not existing:
        print("Substrate operates using your Claude Pro or Max subscription.")
        print("Launching OAuth authorization...")
        result = subprocess.run(["claude", "auth", "login", "--claudeai"])
        if result.returncode != 0:
            print("Authorization failed. Make sure 'claude' is installed and try again.", file=sys.stderr)
            sys.exit(1)
        # Verify the token is now present
        token = _read_claude_oauth_token()
        if token:
            print(f"\n✓ Authorization confirmed.")
        else:
            print("\n⚠ Authorization may have succeeded but token not yet readable from keychain.")
            print("  Try running 'substrate start' — it will pick it up from the Claude Code environment.")
        return

    # Default: already authorized
    print(f"✓ Already authorized (token: {existing[:20]}...)")
    print("  Run 'substrate auth login' to refresh.")


def cmd_search(rest: list[str]) -> None:
    """
    Manage semantic search for this instance.

    Usage:
      substrate search setup    Install embedding model (run once after install)
      substrate search rebuild  Rebuild the search index after bulk entity changes
    """
