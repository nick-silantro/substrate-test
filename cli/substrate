def _substrate_config_path() -> Path:
    return Path("~/.substrate/config.yaml").expanduser()


def _read_update_channel() -> str:
    """Read update_channel from ~/.substrate/config.yaml; default to 'main'."""
    config = _substrate_config_path()
    if not config.exists():
        return "main"
    try:
        import yaml
        data = yaml.safe_load(config.read_text()) or {}
        channel = data.get("update_channel", "main")
        return channel if channel in ("main", "dev") else "main"
    except Exception:
        return "main"


def _set_update_channel(channel: str) -> None:
    """Write update_channel into ~/.substrate/config.yaml."""
    import yaml
    config = _substrate_config_path()
    config.parent.mkdir(parents=True, exist_ok=True)
    data = {}
    if config.exists():
        data = yaml.safe_load(config.read_text()) or {}
    data["update_channel"] = channel
    config.write_text(yaml.dump(data, default_flow_style=False, sort_keys=False))


def _is_substrate_instance(path: Path) -> bool:
    return (path / "CLAUDE.md").exists() and (path / "entities").exists()


def _setup_venv(target: Path) -> None:
    """Create _system/venv and install watchdog for entity-watcher."""
    venv = target / "_system" / "venv"
    if not venv.exists():
        result = subprocess.run([sys.executable, "-m", "venv", str(venv)], capture_output=True, text=True)
        if result.returncode != 0:
            print(f"  ! venv creation failed — entity-watcher won't start: {result.stderr.strip()}")
            return
    pip = venv / "bin" / "pip"
    result = subprocess.run([str(pip), "install", "watchdog", "--quiet"], capture_output=True, text=True)
    if result.returncode == 0:
        print("  ✓ venv: watchdog installed (entity-watcher)")
    else:
        print(f"  ! watchdog install failed: {result.stderr.strip()}")


def _install_services(target: Path, ep: Path, *, reinstall: bool = False) -> None:
    """Generate service unit files from deploy templates and install them."""
    import platform

    deploy_dir = ep / "_system" / "deploy"
    if not deploy_dir.exists():
        return

    home = Path.home()
    substrate_bin = Path(sys.argv[0]).resolve()
    subs = {
        "__WORKSPACE__": str(target),
        "__ENGINE__":    str(ep),
        "__HOME__":      str(home),
        "__USER__":      os.environ.get("USER", home.name),
        "__SUBSTRATE__": str(substrate_bin),
    }

    def apply_subs(text: str) -> str:
        for k, v in subs.items():
            text = text.replace(k, v)
        return text

    system = platform.system()

    if system == "Darwin":
        agents_dir = home / "Library" / "LaunchAgents"
        agents_dir.mkdir(parents=True, exist_ok=True)
        uid = os.getuid()
        domain = f"gui/{uid}"

        for template in sorted(deploy_dir.glob("com.substrate.*.plist")):
            label = template.stem
            dest = agents_dir / template.name

            if dest.exists() and not reinstall:
                print(f"  • {label}: already installed (skipping — use --reinit to update)")
                continue

            dest.write_text(apply_subs(template.read_text()))

            if reinstall:
                subprocess.run(["launchctl", "bootout", f"{domain}/{label}"],
                               capture_output=True)
            result = subprocess.run(["launchctl", "bootstrap", domain, str(dest)],
                                    capture_output=True, text=True)
            if result.returncode == 0:
                print(f"  ✓ {label}: installed and loaded")
            else:
                print(f"  ✓ {label}: installed (load failed — may need manual: "
                      f"launchctl bootstrap {domain} {dest})")

    elif system == "Linux":
        user_systemd = home / ".config" / "systemd" / "user"
        user_systemd.mkdir(parents=True, exist_ok=True)

        for template in sorted(deploy_dir.glob("substrate-*.service")):
            dest = user_systemd / template.name
            dest.write_text(apply_subs(template.read_text()))
            print(f"  ✓ {template.name}: written to {dest}")

        subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)
        print("  Run: systemctl --user enable --now substrate-entity-watcher")

    elif system == "Windows":
        _install_services_windows(target, ep, home, substrate_bin, reinstall)

    else:
        print(f"  (service installation not supported on {system})")


def _install_services_windows(
    target: Path, ep: Path, home: Path, substrate_bin: Path, reinstall: bool
) -> None:
    """Register Substrate background services as Windows Task Scheduler tasks.

    entity-watcher: runs at logon, restarts on failure (equivalent of launchd KeepAlive).
    evaluate-triggers: runs every 5 minutes (equivalent of launchd StartInterval 300).

    Both use generated .cmd wrappers to set SUBSTRATE_PATH and SUBSTRATE_ENGINE_PATH
    before launching, since Task Scheduler tasks don't have a native env-vars block.
    """
    logs_dir = target / "_system" / "logs"
    logs_dir.mkdir(parents=True, exist_ok=True)
    venv_python = target / "_system" / "venv" / "Scripts" / "python.exe"
    local_bin = home / ".local" / "bin"
    substrate_bat = local_bin / "substrate.bat"

    tasks = [
        {
            "label": "substrate-entity-watcher",
            "task_name": "Substrate\\EntityWatcher",
            "cmd_name": "_run-entity-watcher.cmd",
            "cmd_body": (
                f'@echo off\n'
                f'set SUBSTRATE_PATH={target}\n'
                f'set SUBSTRATE_ENGINE_PATH={ep}\n'
                f'"{venv_python}" "{ep / "_system" / "scripts" / "entity-watcher.py"}"\n'
            ),
            "xml": lambda cmd_path: _entity_watcher_xml(cmd_path, target, logs_dir),
            "start_immediately": True,
        },
        {
            "label": "substrate-evaluate-triggers",
            "task_name": "Substrate\\EvaluateTriggers",
            "cmd_name": "_run-evaluate-triggers.cmd",
            "cmd_body": (
                f'@echo off\n'
                f'set SUBSTRATE_PATH={target}\n'
                f'set SUBSTRATE_ENGINE_PATH={ep}\n'
                f'set PATH={local_bin};%PATH%\n'
                f'"{substrate_bat}" triggers evaluate\n'
            ),
            "xml": lambda cmd_path: _evaluate_triggers_xml(cmd_path, target, logs_dir),
            "start_immediately": False,
        },
    ]

    for task in tasks:
        cmd_path = target / "_system" / "scripts" / task["cmd_name"]
        cmd_path.write_text(task["cmd_body"], encoding="utf-8")

        xml_content = task["xml"](cmd_path)
        xml_path = target / "_system" / f'_task_{task["label"]}.xml'
        xml_path.write_text(xml_content, encoding="utf-16")

        if reinstall:
            subprocess.run(
                ["schtasks", "/Delete", "/TN", task["task_name"], "/F"],
                capture_output=True,
            )

        r = subprocess.run(
            ["schtasks", "/Create", "/TN", task["task_name"], "/XML", str(xml_path), "/F"],
            capture_output=True, text=True,
        )
        xml_path.unlink(missing_ok=True)

        if r.returncode == 0:
            print(f"  ✓ {task['label']}: installed")
            if task["start_immediately"]:
                subprocess.run(
                    ["schtasks", "/Run", "/TN", task["task_name"]],
                    capture_output=True,
                )
        else:
            print(f"  ! {task['label']}: install failed — {r.stderr.strip()}")


def _entity_watcher_xml(cmd_path: Path, workspace: Path, logs_dir: Path) -> str:
    return f"""<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Substrate entity watcher — auto-bumps last_edited on entity content changes</Description>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger><Enabled>true</Enabled></LogonTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>999</Count>
    </RestartOnFailure>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>{cmd_path}</Command>
      <WorkingDirectory>{workspace}</WorkingDirectory>
    </Exec>
  </Actions>
</Task>"""


def _evaluate_triggers_xml(cmd_path: Path, workspace: Path, logs_dir: Path) -> str:
    return f"""<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Substrate trigger evaluator — runs every 5 minutes</Description>
  </RegistrationInfo>
