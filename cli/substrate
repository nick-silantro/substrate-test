def _find_workspace_from_cwd() -> Path | None:
    """Walk up from CWD to find the root of a Substrate workspace."""
    current = Path.cwd()
    while True:
        if (current / "_system").is_dir() and (current / "CLAUDE.md").exists():
            return current
        parent = current.parent
        if parent == current:
            return None
        current = parent


def _engine_from_overlay(workspace: Path) -> Path | None:
    """Read the engine path from a workspace's overlay.yaml if declared."""
    overlay = workspace / "_system" / "overlay.yaml"
    if not overlay.exists():
        return None
    try:
        # Try yaml.safe_load first (full overlay support)
        try:
            import yaml as _yaml_ov
            data = _yaml_ov.safe_load(overlay.read_text()) or {}
            if isinstance(data, dict) and "engine" in data:
                value = str(data["engine"]).strip()
                if value:
                    return Path(value).expanduser().resolve()
        except Exception:
            pass
        # Fallback: line-by-line parser for simple engine: key
        for line in overlay.read_text().splitlines():
            if line.startswith("engine:"):
                value = line.split(":", 1)[1].strip()
                if value:
                    return Path(value).expanduser().resolve()
    except Exception:
        pass
    return None


def _load_overlay() -> dict:
    """Load overlay.yaml from the current workspace. Returns {} if missing."""
    ip = instance_path()
    overlay_path = ip / "_system" / "overlay.yaml"
    if not overlay_path.exists():
        return {}
    try:
        import yaml as _yaml_ov
        data = _yaml_ov.safe_load(overlay_path.read_text()) or {}
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def _save_overlay(data: dict) -> None:
    """Write overlay.yaml back to the workspace.
    NOTE: yaml.dump does not preserve hand-written comments — PyYAML limitation.
    """
    import yaml as _yaml_ov
    ip = instance_path()
    overlay_path = ip / "_system" / "overlay.yaml"
    overlay_path.parent.mkdir(parents=True, exist_ok=True)
    overlay_path.write_text(_yaml_ov.dump(data, default_flow_style=False, sort_keys=False))


def _resolve_type_alias(name: str, aliases: dict | None = None) -> str:
    """Resolve a type name through overlay aliases. Returns canonical. Warns on collision."""
    if aliases is None:
        aliases = _load_overlay().get("aliases", {})
    type_aliases = aliases.get("types", {})
    if not type_aliases:
        return name
    # Build reverse map: alias_target -> canonical
    reverse = {v: k for k, v in type_aliases.items() if isinstance(v, str)}
    if name in reverse:
        canonical = reverse[name]
        # Defensive collision check: if name also matches a canonical, canonical wins
        ip = instance_path()
        ep = engine_path(ip)
        try:
            import sys as _sys
            scripts_dir = str(ep / "_system" / "scripts")
            if scripts_dir not in _sys.path:
                _sys.path.insert(0, scripts_dir)
            from schema import load_schema as _ls
            schema = _ls(str(ip))
            if name in schema.known_types:
                print(f"warning: alias '{name}' is shadowed by a canonical name — run 'substrate schema alias check' to review", file=sys.stderr)
                return name
        except Exception:
            pass
        return canonical
    return name


def _resolve_attribute_alias(name: str, aliases: dict | None = None) -> str:
    """Resolve an attribute name through overlay aliases."""
    if aliases is None:
        aliases = _load_overlay().get("aliases", {})
    attr_aliases = aliases.get("attributes", {})
    reverse = {v: k for k, v in attr_aliases.items() if isinstance(v, str)}
    if name in reverse:
        return reverse[name]
    return name


def _resolve_relationship_alias(name: str, aliases: dict | None = None) -> str:
    """Resolve a relationship name through overlay aliases."""
    if aliases is None:
        aliases = _load_overlay().get("aliases", {})
    rel_aliases = aliases.get("relationships", {})
    reverse = {v: k for k, v in rel_aliases.items() if isinstance(v, str)}
    if name in reverse:
        return reverse[name]
    return name


def _check_alias_collisions(schema, overlay_aliases: dict) -> list[dict]:
    """Return list of {kind, alias, canonical, collision_with} for any collisions."""
    collisions = []

    # Collect canonical names
    canonical_types = set(schema.known_types)
    # All attribute names from all sections
    canonical_attrs = set()
    canonical_attrs.update(schema.attributes.get("attributes", {}).keys())
    canonical_attrs.update(schema.attributes.get("universal", {}).keys())
    for block_def in schema.attributes.get("blocks", {}).values():
        canonical_attrs.update(block_def.get("fields", {}).keys())
    canonical_attrs.update(schema.attributes.get("dimensions", {}).keys())
    # All relationship names (forward + inverse)
    canonical_rels = set(schema.relationship_names)

    type_aliases = overlay_aliases.get("types", {})
    attr_aliases = overlay_aliases.get("attributes", {})
    rel_aliases = overlay_aliases.get("relationships", {})

    # Check type aliases
    seen_type_targets = {}
    for canonical, alias_target in type_aliases.items():
        if alias_target in canonical_types:
            collisions.append({"kind": "type", "alias": alias_target, "canonical": canonical, "collision_with": alias_target})
        elif alias_target in seen_type_targets and seen_type_targets[alias_target] != canonical:
            collisions.append({"kind": "type", "alias": alias_target, "canonical": canonical, "collision_with": f"alias for '{seen_type_targets[alias_target]}'"})
        else:
            seen_type_targets[alias_target] = canonical

    # Check attribute aliases
    seen_attr_targets = {}
    for canonical, alias_target in attr_aliases.items():
        if alias_target in canonical_attrs:
            collisions.append({"kind": "attribute", "alias": alias_target, "canonical": canonical, "collision_with": alias_target})
        elif alias_target in seen_attr_targets and seen_attr_targets[alias_target] != canonical:
            collisions.append({"kind": "attribute", "alias": alias_target, "canonical": canonical, "collision_with": f"alias for '{seen_attr_targets[alias_target]}'"})
        else:
            seen_attr_targets[alias_target] = canonical

    # Check relationship aliases
    seen_rel_targets = {}
    for canonical, alias_target in rel_aliases.items():
        if alias_target in canonical_rels:
            collisions.append({"kind": "relationship", "alias": alias_target, "canonical": canonical, "collision_with": alias_target})
        elif alias_target in seen_rel_targets and seen_rel_targets[alias_target] != canonical:
            collisions.append({"kind": "relationship", "alias": alias_target, "canonical": canonical, "collision_with": f"alias for '{seen_rel_targets[alias_target]}'"})
        else:
            seen_rel_targets[alias_target] = canonical

    return collisions


def instance_path() -> Path:
    # 1. Explicit env var
    ip = os.environ.get("SUBSTRATE_PATH")
    if ip:
        return Path(ip).expanduser().resolve()
    # 2. CWD detection — walk up to find a Substrate workspace
    found = _find_workspace_from_cwd()
    if found:
        return found
    # 3. Default
    default = Path("~/substrate").expanduser()
    if default.exists():
        return default
    return Path.cwd()


def engine_path(workspace: Path | None = None) -> Path:
    # 1. Explicit env var
    ep = os.environ.get("SUBSTRATE_ENGINE_PATH")
    if ep:
        return Path(ep).expanduser().resolve()
    # 2. Workspace overlay.yaml
    ws = workspace if workspace is not None else instance_path()
    overlay_engine = _engine_from_overlay(ws)
    if overlay_engine:
        return overlay_engine
    # 3. Default installed engine
    pulled = Path("~/.substrate/engine").expanduser()
    if pulled.exists():
        return pulled
    # 4. Dev fallback: CLI lives at {engine}/cli/substrate
    return Path(__file__).resolve().parents[1]


def script(name: str) -> Path:
    return engine_path() / "_system" / "scripts" / name


def run(script_name: str, args: list[str], stdin_json=None) -> None:
    ip = instance_path()
    ep = engine_path(ip)
    env = {
        **os.environ,
        "SUBSTRATE_PATH": str(ip),
        "SUBSTRATE_ENGINE_PATH": str(ep),
    }
    s = script(script_name)
    if not s.exists():
        print(f"substrate: script not found: {s}", file=sys.stderr)
        sys.exit(2)
    cmd = ["python3", str(s)] + args
    result = subprocess.run(
        cmd,
        env=env,
        input=json.dumps(stdin_json) if stdin_json is not None else None,
        text=True,
    )
    sys.exit(result.returncode)


