def _install_services(target: Path, ep: Path, *, reinstall: bool = False) -> None:
    """Generate service unit files from deploy templates and install them."""
    import platform
    import re as _re

    deploy_dir = ep / "_system" / "deploy"
    if not deploy_dir.exists():
        return

    home = Path.home()
    substrate_bin = Path(sys.argv[0]).resolve()

    # Workspace slug — unique suffix baked into every service label so multiple
    # workspaces on one machine each get their own independent services.
    slug = _re.sub(r'[^a-z0-9]+', '-', target.name.lower()).strip('-') or 'workspace'

    subs = {
        "__WORKSPACE__": str(target),
        "__ENGINE__":    str(ep),
        "__HOME__":      str(home),
        "__USER__":      os.environ.get("USER", home.name),
        "__SUBSTRATE__": str(substrate_bin),
        "__SLUG__":      slug,
    }

    def apply_subs(text: str) -> str:
        for k, v in subs.items():
            text = text.replace(k, v)
        return text

    system = platform.system()

    if system == "Darwin":
        agents_dir = home / "Library" / "LaunchAgents"
        agents_dir.mkdir(parents=True, exist_ok=True)
        uid = os.getuid()
        domain = f"gui/{uid}"

        if reinstall:
            # Clean up old singleton-format plists (pre-slug) that belong to this workspace.
            for template in deploy_dir.glob("com.substrate.*.plist"):
                old_dest = agents_dir / template.name
                if old_dest.exists() and str(target) in old_dest.read_text():
                    old_label = template.stem
                    subprocess.run(["launchctl", "bootout", f"{domain}/{old_label}"],
                                   capture_output=True)
                    old_dest.unlink(missing_ok=True)

        for template in sorted(deploy_dir.glob("com.substrate.*.plist")):
            label = f"{template.stem}.{slug}"
            dest = agents_dir / f"{label}.plist"

            if dest.exists() and not reinstall:
                print(f"  • {label}: already installed (skipping — use --reinit to update)")
                continue

            dest.write_text(apply_subs(template.read_text()))

            if reinstall:
                subprocess.run(["launchctl", "bootout", f"{domain}/{label}"],
                               capture_output=True)
            result = subprocess.run(["launchctl", "bootstrap", domain, str(dest)],
                                    capture_output=True, text=True)
            if result.returncode == 0:
                print(f"  ✓ {label}: installed and loaded")
            else:
                print(f"  ✓ {label}: installed (load failed — may need manual: "
                      f"launchctl bootstrap {domain} {dest})")

    elif system == "Linux":
        user_systemd = home / ".config" / "systemd" / "user"
        user_systemd.mkdir(parents=True, exist_ok=True)
        (target / "_system" / "logs").mkdir(parents=True, exist_ok=True)

        if reinstall:
            # Clean up old singleton-format units (pre-slug) that belong to this workspace.
            for template in list(deploy_dir.glob("substrate-*.service")) + \
                            list(deploy_dir.glob("substrate-*.timer")):
                old_dest = user_systemd / template.name
                if old_dest.exists() and str(target) in old_dest.read_text():
                    subprocess.run(
                        ["systemctl", "--user", "disable", "--now", template.name],
                        capture_output=True,
                    )
                    old_dest.unlink(missing_ok=True)

        newly_written: list[str] = []

        templates = sorted(deploy_dir.glob("substrate-*.service")) + \
                    sorted(deploy_dir.glob("substrate-*.timer"))
        for template in templates:
            unit_name = f"{template.stem}-{slug}{template.suffix}"
            unit_label = f"{template.stem}-{slug}"
            dest = user_systemd / unit_name

            if dest.exists() and not reinstall:
                print(f"  • {unit_label}: already installed (skipping — use --reinit to update)")
                continue

            if reinstall and dest.exists():
                subprocess.run(
                    ["systemctl", "--user", "disable", "--now", unit_name],
                    capture_output=True,
                )

            dest.write_text(apply_subs(template.read_text()))
            newly_written.append(unit_name)

        subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)

        # Timer-backed services are activated by their timer — don't enable directly.
        all_timers = {t.name for t in user_systemd.glob("substrate-*.timer")}
        timer_backed = {t.replace(".timer", ".service") for t in all_timers}

        for unit_name in newly_written:
            unit_label = unit_name.replace(".service", "").replace(".timer", "")
            if unit_name.endswith(".service") and unit_name in timer_backed:
                print(f"  ✓ {unit_label}: written (activated by its timer)")
                continue
            result = subprocess.run(
                ["systemctl", "--user", "enable", "--now", unit_name],
                capture_output=True, text=True,
            )
            if result.returncode == 0:
                kind = "timer enabled and running" if unit_name.endswith(".timer") else "enabled and started"
                print(f"  ✓ {unit_label}: {kind}")
            else:
                print(f"  ✓ {unit_label}: written — enable manually:")
                print(f"      systemctl --user enable --now {unit_name}")

    elif system == "Windows":
        _install_services_windows(target, ep, home, substrate_bin, reinstall, slug)

    else:
        print(f"  (service installation not supported on {system})")


def _install_services_windows(
    target: Path, ep: Path, home: Path, substrate_bin: Path, reinstall: bool, slug: str
) -> None:
    """Register Substrate background services as Windows Task Scheduler tasks.

    entity-watcher: runs at logon, restarts on failure (equivalent of launchd KeepAlive).
    evaluate-triggers: runs every 5 minutes (equivalent of launchd StartInterval 300).

    Both use generated .cmd wrappers to set SUBSTRATE_PATH and SUBSTRATE_ENGINE_PATH
    before launching, since Task Scheduler tasks don't have a native env-vars block.
    """
    logs_dir = target / "_system" / "logs"
    logs_dir.mkdir(parents=True, exist_ok=True)
    venv_python = target / "_system" / "venv" / "Scripts" / "python.exe"
    local_bin = home / ".local" / "bin"
    substrate_bat = local_bin / "substrate.bat"

    tasks = [
        {
            "label": f"substrate-entity-watcher-{slug}",
            "task_name": f"Substrate\\EntityWatcher-{slug}",
            "cmd_name": f"_run-entity-watcher-{slug}.cmd",
            "cmd_body": (
                f'@echo off\n'
                f'set SUBSTRATE_PATH={target}\n'
                f'set SUBSTRATE_ENGINE_PATH={ep}\n'
                f'"{venv_python}" "{ep / "_system" / "scripts" / "entity-watcher.py"}"\n'
            ),
            "xml": lambda cmd_path: _entity_watcher_xml(cmd_path, target, logs_dir),
            "start_immediately": True,
            "registry_fallback": True,
        },
        {
            "label": f"substrate-evaluate-triggers-{slug}",
            "task_name": f"Substrate\\EvaluateTriggers-{slug}",
            "cmd_name": f"_run-evaluate-triggers-{slug}.cmd",
            "cmd_body": (
                f'@echo off\n'
                f'set SUBSTRATE_PATH={target}\n'
                f'set SUBSTRATE_ENGINE_PATH={ep}\n'
                f'set PATH={local_bin};%PATH%\n'
                f'"{substrate_bat}" triggers evaluate\n'
            ),
            "xml": lambda cmd_path: _evaluate_triggers_xml(cmd_path, target, logs_dir),
            "start_immediately": False,
        },
        {
            "label": f"substrate-check-for-updates-{slug}",
            "task_name": f"Substrate\\CheckForUpdates-{slug}",
            "cmd_name": f"_run-check-for-updates-{slug}.cmd",
            "cmd_body": (
                f'@echo off\n'
                f'set SUBSTRATE_PATH={target}\n'
                f'set SUBSTRATE_ENGINE_PATH={ep}\n'
                f'set PATH={local_bin};%PATH%\n'
                f'"{substrate_bat}" check-for-updates\n'
            ),
            "xml": lambda cmd_path: _check_for_updates_xml(cmd_path, target, logs_dir),
            "start_immediately": False,
        },
    ]

    (target / "_system" / "scripts").mkdir(parents=True, exist_ok=True)

    for task in tasks:
        cmd_path = target / "_system" / "scripts" / task["cmd_name"]
        cmd_path.write_text(task["cmd_body"], encoding="utf-8")

        xml_content = task["xml"](cmd_path)
        xml_path = target / "_system" / f'_task_{task["label"]}.xml'
        xml_path.write_text(xml_content, encoding="utf-16")

        if reinstall:
            subprocess.run(
                ["schtasks", "/Delete", "/TN", task["task_name"], "/F"],
                capture_output=True,
            )

        r = subprocess.run(
            ["schtasks", "/Create", "/TN", task["task_name"], "/XML", str(xml_path), "/F"],
            capture_output=True, text=True,
        )
        xml_path.unlink(missing_ok=True)

        if r.returncode == 0:
            print(f"  ✓ {task['label']}: installed")
            if task["start_immediately"]:
                subprocess.run(
                    ["schtasks", "/Run", "/TN", task["task_name"]],
                    capture_output=True,
                )
        elif task.get("registry_fallback"):
            _install_via_registry_run(task["label"], cmd_path)
        else:
            print(f"  ! {task['label']}: install failed — {r.stderr.strip()}")


def _install_via_registry_run(label: str, cmd_path: Path) -> None:
    """Fallback: register cmd_path in HKCU Run key (no elevation required)."""
    try:
        import winreg
        with winreg.OpenKey(
            winreg.HKEY_CURRENT_USER,
            r"Software\Microsoft\Windows\CurrentVersion\Run",
            0,
            winreg.KEY_SET_VALUE,
        ) as key:
            winreg.SetValueEx(key, label, 0, winreg.REG_SZ, f'"{cmd_path}"')
        subprocess.Popen([str(cmd_path)], creationflags=0x00000008)  # DETACHED_PROCESS
        print(f"  ✓ {label}: installed via registry Run key (starts at logon)")
    except Exception as e:
        print(f"  ! {label}: Task Scheduler and registry fallback both failed — {e}")
        print(f"    To start manually: {cmd_path}")


def _entity_watcher_xml(cmd_path: Path, workspace: Path, logs_dir: Path) -> str:
    return f"""<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Substrate entity watcher — auto-bumps last_edited on entity content changes</Description>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger><Enabled>true</Enabled></LogonTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>999</Count>
    </RestartOnFailure>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>{cmd_path}</Command>
      <WorkingDirectory>{workspace}</WorkingDirectory>
    </Exec>
  </Actions>
</Task>"""


