def cmd_test(rest: list[str]) -> None:
    """Run the integration test suite against this engine installation."""
    ep = engine_path()
    tests_dir = ep / "tests"

    if not tests_dir.exists():
        print("substrate test: tests/ directory not found in engine.", file=sys.stderr)
        print(f"  Expected: {tests_dir}", file=sys.stderr)
        sys.exit(1)

    # Check pytest is available
    check = subprocess.run(
        [sys.executable, "-m", "pytest", "--version"],
        capture_output=True
    )
    if check.returncode != 0:
        print("substrate test: pytest not found.", file=sys.stderr)
        print("  Install it with:  python3 -m pip install pytest", file=sys.stderr)
        sys.exit(1)

    # Make the substrate binary discoverable inside test subprocesses.
    # Prefer the directory containing this script (works for both installed
    # and dev-symlinked engines), falling back to the engine's cli/ dir.
    cli_dir = Path(sys.argv[0]).resolve().parent
    if not (cli_dir / "substrate").exists():
        cli_dir = ep / "cli"
    existing_path = os.environ.get("PATH", "")
    new_path = f"{cli_dir}{os.pathsep}{existing_path}"

    env = {
        **os.environ,
        "SUBSTRATE_ENGINE_PATH": str(ep),
        "SUBSTRATE_PATH": str(instance_path()),
        "PATH": new_path,
    }

    cmd = [sys.executable, "-m", "pytest", str(tests_dir)] + rest
    result = subprocess.run(cmd, env=env)
    sys.exit(result.returncode)


