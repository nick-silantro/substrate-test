def cmd_update_snooze(_rest: list[str]) -> None:
    """Record the currently pending updates as declined by the user.

    Reads pending-updates.md to find the versions being snoozed, writes
    _system/update-snooze.yaml. check-for-updates will skip these versions
    until a newer release is detected.
    """
    import re
    ip = instance_path()
    pending = ip / "_system" / "docs" / "pending-updates.md"
    snooze_file = ip / "_system" / "update-snooze.yaml"

    if not pending.exists():
        print("No pending updates — nothing to snooze.")
        return

    content = pending.read_text(encoding="utf-8")

    snooze: dict = {}
    if snooze_file.exists():
        try:
            import yaml
            snooze = yaml.safe_load(snooze_file.read_text()) or {}
        except Exception:
            snooze = {}

    # Parse Agent SDK version from "Agent SDK (`...`): X.X.X → Y.Y.Y"
    sdk_match = re.search(r"Agent SDK[^:]*:\s*[\d.]+\s*→\s*([\d.]+)", content)
    if sdk_match:
        snooze["agent_sdk"] = sdk_match.group(1)
        print(f"  Snoozed Agent SDK {sdk_match.group(1)}")

    # Parse Claude CLI version from "Claude Code CLI: X.X.X → Y.Y.Y"
    cli_match = re.search(r"Claude Code CLI:\s*[\d.]+\s*→\s*([\d.]+)", content)
    if cli_match:
        snooze["claude_cli"] = cli_match.group(1)
        print(f"  Snoozed Claude Code CLI {cli_match.group(1)}")

    # Parse Substrate: get the latest commit hash from the engine
    if "## Substrate Engine" in content:
        ep = engine_path()
        result = subprocess.run(
            ["git", "rev-parse", "origin/main"],
            cwd=ep, capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0:
            snooze["substrate"] = result.stdout.strip()
            print(f"  Snoozed Substrate engine ({result.stdout.strip()[:8]})")

    if not snooze:
        print("Could not parse any versions from pending-updates.md.")
        return

    import yaml
    snooze_file.write_text(yaml.dump(snooze, default_flow_style=False), encoding="utf-8")
    print("\nUpdate snoozed. It will resurface when a newer version is available.")


def cmd_update_anthropic(_rest: list[str]) -> None:
    ep = engine_path()
    ip = instance_path()
    pending = ip / "_system" / "docs" / "pending-updates.md"

    print("Updating Claude Code CLI...")
    result = subprocess.run(["claude", "update"], text=True)
    if result.returncode != 0:
        print("  Warning: claude update returned non-zero — check output above.", file=sys.stderr)

    print("\nUpdating Agent SDK (@anthropic-ai/claude-agent-sdk)...")
    updated_any = False
    for app_dir in ("web/surface", "web/relay"):
        pkg_dir = ep / app_dir
        if (pkg_dir / "package.json").exists():
            print(f"  {app_dir}...")
            subprocess.run(
                ["npm", "install", "@anthropic-ai/claude-agent-sdk@latest"],
                cwd=pkg_dir, text=True
            )
            updated_any = True
    if not updated_any:
        print("  No Surface/Relay app directories found — skipping SDK update.", file=sys.stderr)

    if pending.exists():
        pending.unlink()
        print("\nCleared pending-updates.md.")

    snooze_file = ip / "_system" / "update-snooze.yaml"
    if snooze_file.exists():
        try:
            import yaml
            snooze = yaml.safe_load(snooze_file.read_text()) or {}
            snooze.pop("agent_sdk", None)
            snooze.pop("claude_cli", None)
            if snooze:
                snooze_file.write_text(yaml.dump(snooze, default_flow_style=False))
            else:
                snooze_file.unlink()
        except Exception:
            pass

    print("\nDone. Run 'substrate check-for-updates' to re-check status.")


def cmd_update(_rest: list[str]) -> None:
    ep = engine_path()
    ip = instance_path()
    channel = _read_update_channel()

    # --- Engine update ---
    print(f"Updating substrate engine (channel: {channel})...")
    git_dir = ep / ".git"
    if not git_dir.exists():
        print("  substrate update: engine is not a git repository — cannot auto-update.")
        print(f"  Engine path: {ep}")
        print(f"  To update manually: git -C <engine-path> pull origin {channel}")
        sys.exit(1)

    _from_version = (ep / "VERSION").read_text().strip() if (ep / "VERSION").exists() else None

    result = subprocess.run(
        ["git", "-C", str(ep), "pull", "--ff-only", "origin", channel],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
        sys.exit(result.returncode)

    if "Already up to date" in result.stdout:
        print(f"  ✓ Engine already up to date ({channel})")
    else:
        print(f"  ✓ Engine updated ({channel})")

    if "Already up to date" not in result.stdout:
        try:
            _to_version = (ep / "VERSION").read_text().strip() if (ep / "VERSION").exists() else None
            if _from_version and _to_version and _from_version != _to_version:
                _machine_id, _ = _ensure_machine_id()
                _platform = {"darwin": "darwin", "linux": "linux", "win32": "win32"}.get(sys.platform, sys.platform)
                _fire_metrics_event("update", _machine_id, version=_to_version, platform=_platform)
        except Exception:
            pass

    # --- Run pending migrations ---
    run_mig = ep / "_system" / "scripts" / "run-migrations.py"
    if run_mig.exists() and ip.exists():
        mig_env = {**os.environ, "SUBSTRATE_PATH": str(ip), "SUBSTRATE_ENGINE_PATH": str(ep)}
        mig_result = subprocess.run([sys.executable, str(run_mig)], env=mig_env)
        if mig_result.returncode != 0:
            print("  ✗ Migration failed — update incomplete.", file=sys.stderr)
            sys.exit(1)

    # --- Link skills from (now-updated) engine to instance ---
    if ip.exists():
        _link_skills(ep / "_system" / "skills", ip / ".claude" / "skills")
        print(f"  ✓ Skills linked")

    # --- Rebuild index ---
    env = {**os.environ, "SUBSTRATE_PATH": str(ip), "SUBSTRATE_ENGINE_PATH": str(ep)}
    s = ep / "_system" / "scripts" / "migrate-to-sqlite.py"
    if s.exists():
        subprocess.run(["python3", str(s)], env=env, check=False, capture_output=True)
        print(f"  ✓ Index rebuilt")

    # --- Check for alias collisions introduced by the update ---
    try:
        scripts_dir = str(ep / "_system" / "scripts")
        if scripts_dir not in sys.path:
            sys.path.insert(0, scripts_dir)
        from schema import load_schema as _ls_upd
        _schema_upd = _ls_upd(str(ip))
        _overlay_upd = _load_overlay()
        _collisions_upd = _check_alias_collisions(_schema_upd, _overlay_upd.get("aliases", {}))
        if _collisions_upd:
            print("\nWarning: the update introduced alias collisions in your overlay.yaml:")
            for c in _collisions_upd:
                print(f"  {c['kind']} alias '{c['alias']}' (for '{c['canonical']}') now conflicts with canonical name '{c['collision_with']}'")
            print("Run 'substrate schema alias check' to review and fix.")
    except Exception:
        pass  # non-fatal

    # --- Clear substrate snooze entry ---
    snooze_file = ip / "_system" / "update-snooze.yaml"
    if snooze_file.exists():
        try:
            import yaml
            snooze = yaml.safe_load(snooze_file.read_text()) or {}
            snooze.pop("substrate", None)
            if snooze:
                snooze_file.write_text(yaml.dump(snooze, default_flow_style=False))
            else:
                snooze_file.unlink()
        except Exception:
            pass

    # --- Ensure semantic search is set up (no-op if already installed) ---
    setup_search = ep / "_system" / "scripts" / "setup-search.py"
    if setup_search.exists():
        env = {**os.environ, "SUBSTRATE_PATH": str(ip), "SUBSTRATE_ENGINE_PATH": str(ep)}
        result = subprocess.run([sys.executable, str(setup_search)], env=env, check=False, capture_output=True)
        if result.returncode == 0:
            print(f"  ✓ Semantic search ready")
        else:
            print(f"  ⚠ Search setup failed — run 'substrate search setup' manually")

    # --- Refresh pending-updates.md now that engine is current ---
    check_script = ep / "_system" / "scripts" / "check-for-updates.py"
    if check_script.exists():
        env = {**os.environ, "SUBSTRATE_PATH": str(ip), "SUBSTRATE_ENGINE_PATH": str(ep)}
        subprocess.run([sys.executable, str(check_script)], env=env, check=False, capture_output=True)


def cmd_sync(_rest: list[str]) -> None:
    """Link skills from engine to instance and rebuild the SQLite index."""
    ep = engine_path()
    ip = instance_path()

    _link_skills(ep / "_system" / "skills", ip / ".claude" / "skills")
    if (ep / "_system" / "skills").exists():
        print(f"✓ Skills linked from engine")

    env = {**os.environ, "SUBSTRATE_PATH": str(ip), "SUBSTRATE_ENGINE_PATH": str(ep)}
    s = ep / "_system" / "scripts" / "migrate-to-sqlite.py"
    if s.exists():
        subprocess.run(["python3", str(s)], env=env, check=False, capture_output=True)
        print(f"✓ Index rebuilt")




def cmd_channel(rest: list[str]) -> None:
    """Show or set the engine update channel (machine-wide, not per-instance)."""
    if not rest or rest[0] in ("-h", "--help"):
        channel = _read_update_channel()
        print(f"Update channel: {channel}")
        print(f"  main  — stable releases (default)")
        print(f"  dev   — beta/staging channel")
        print()
        print(f"Config: {_substrate_config_path()}")
        print(f"To change: substrate channel set <main|dev>")
        return

    if rest[0] == "set":
        if len(rest) < 2 or rest[1] not in ("main", "dev"):
            print("Usage: substrate channel set <main|dev>", file=sys.stderr)
            sys.exit(1)
        try:
            _set_update_channel(rest[1])
            print(f"✓ Update channel set to '{rest[1]}'")
            print(f"  Next `substrate update` will pull from the '{rest[1]}' branch.")
            print(f"  Config: {_substrate_config_path()}")
        except Exception as exc:
            print(f"Error: could not write {_substrate_config_path()} — {exc}", file=sys.stderr)
            sys.exit(1)
    else:
        print(f"substrate channel: unknown subcommand '{rest[0]}'", file=sys.stderr)
        print("Usage: substrate channel [set <main|dev>]", file=sys.stderr)
        sys.exit(1)


def cmd_version(_rest: list[str]) -> None:
    ep = engine_path()
    # Try to get git tag / commit
    version = "unknown"
    try:
        tag = subprocess.run(
            ["git", "-C", str(ep), "describe", "--tags", "--abbrev=0"],
            capture_output=True, text=True,
        )
        if tag.returncode == 0:
            version = tag.stdout.strip()
            # Also get short commit for precision
            commit = subprocess.run(
                ["git", "-C", str(ep), "rev-parse", "--short", "HEAD"],
                capture_output=True, text=True,
            )
            if commit.returncode == 0:
                version = f"{version} ({commit.stdout.strip()})"
    except FileNotFoundError:
        pass  # git not available
    print(f"substrate {version}")
    print(f"  engine:   {ep}")
    print(f"  instance: {instance_path()}")


