def cmd_schema_add_type(rest: list[str]) -> None:
    p = argparse.ArgumentParser(prog="substrate schema add type")
    p.add_argument("name")
    p.add_argument("--grouping", required=True)
    p.add_argument("--description", default="")
    args = p.parse_args(rest)
    payload = {"name": args.name, "grouping": args.grouping}
    if args.description:
        payload["description"] = args.description
    run("schema-add-type.py", [], stdin_json=payload)


def cmd_schema_add_attribute(rest: list[str]) -> None:
    p = argparse.ArgumentParser(prog="substrate schema add attribute")
    p.add_argument("name")
    p.add_argument("--on", dest="on_types", default="")
    p.add_argument("--data-type", default="string")
    p.add_argument("--description", default="")
    p.add_argument("--required", action="store_true")
    p.add_argument("--values", default="")
    args = p.parse_args(rest)

    payload: dict = {"name": args.name, "data_type": args.data_type}
    if args.description:
        payload["description"] = args.description
    if args.values:
        payload["values"] = [v.strip() for v in args.values.split(",")]
    if args.on_types:
        types = [t.strip() for t in args.on_types.split(",")]
        tier = "required" if args.required else "preferred"
        payload["access"] = {tier: {"types": types}}
    run("schema-add-attribute.py", [], stdin_json=payload)


