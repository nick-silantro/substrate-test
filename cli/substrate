def cmd_verify(_rest: list[str]) -> None:
    """Lightweight end-user health check — no pytest required."""
    import sqlite3
    import yaml as _yaml

    ok = True

    def check(label: str, passed: bool, detail: str = "") -> None:
        nonlocal ok
        status = "ok" if passed else "FAIL"
        line = f"  [{status}] {label}"
        if detail:
            line += f" — {detail}"
        print(line)
        if not passed:
            ok = False

    ip = instance_path()

    print("substrate verify")
    print()

    # 1. Engine path exists
    ep = engine_path()
    check("engine path exists", ep.exists(), str(ep))

    # 2. Instance path exists
    check("instance path exists", ip.exists(), str(ip))

    # 3. Required workspace directories
    for d in ("entities", "assets", "staging", "_system/index"):
        check(f"directory: {d}", (ip / d).is_dir())

    # 4. SQLite index exists and is readable
    db_path = ip / "_system" / "index" / "substrate.db"
    db_ok = False
    db_detail = ""
    if db_path.exists():
        try:
            conn = sqlite3.connect(db_path)
            conn.execute("SELECT COUNT(*) FROM entities")
            conn.close()
            db_ok = True
        except Exception as e:
            db_detail = str(e)
    else:
        db_detail = "file not found"
    check("sqlite index readable", db_ok, db_detail)

    # 5. overlay.yaml is valid YAML
    overlay = ip / "_system" / "overlay.yaml"
    overlay_ok = False
    overlay_detail = ""
    if overlay.exists():
        try:
            _yaml.safe_load(overlay.read_text())
            overlay_ok = True
        except Exception as e:
            overlay_detail = str(e)
    else:
        overlay_detail = "file not found"
    check("overlay.yaml valid", overlay_ok, overlay_detail)

    # 6. Engine scripts directory
    scripts_dir = ep / "_system" / "scripts"
    check("engine scripts present", scripts_dir.is_dir())

    # 7. Schema files present
    schema_dir = ep / "_system" / "schema"
    check("engine schema present", schema_dir.is_dir())

    print()
    if ok:
        print("All checks passed.")
    else:
        print("One or more checks failed. Run 'substrate validate' for details.")
        sys.exit(1)


