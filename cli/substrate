def main() -> None:
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print_help()
        sys.exit(0)

    # Try longest match first (3 tokens, then 2, then 1)
    for length in (3, 2, 1):
        key = tuple(args[:length])
        if key in COMMANDS:
            COMMANDS[key](args[length:])
            return

    print(f"substrate: unknown command '{' '.join(args[:2])}'", file=sys.stderr)
    print("Run 'substrate help' for usage.", file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    main()
