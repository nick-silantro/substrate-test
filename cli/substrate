def cmd_context(rest: list[str]) -> None:
    if not rest or rest[0] in ("-h", "--help"):
        print("Usage: substrate context <doc-name>")
        print("       substrate context list")
        print("       substrate context context-stack [level]   (default level: L0)")
        sys.exit(0)

    ip = instance_path()
    ep = engine_path(ip)

    if rest[0] == "list":
        names = set()
        docs_dir = ep / "_system" / "docs"
        skills_dir = ip / ".claude" / "skills"
        if docs_dir.exists():
            for f in docs_dir.glob("*.md"):
                names.add(f.stem)
        if skills_dir.exists():
            for d in skills_dir.iterdir():
                if d.is_dir() and (d / "SKILL.md").exists():
                    names.add(d.name)
        for name in sorted(names):
            print(name)
        return

    name = rest[0]

    # Special case: context-stack runs the workspace context stack query
    if name == "context-stack":
        level = rest[1] if len(rest) > 1 else "L0"
        script = ep / "_system" / "scripts" / "query-context-stack.py"
        if not script.exists():
            print("substrate context: context-stack script not found in engine", file=sys.stderr)
            sys.exit(1)
        env = {**os.environ, "SUBSTRATE_PATH": str(ip), "SUBSTRATE_ENGINE_PATH": str(ep)}
        result = subprocess.run(
            [sys.executable, str(script), "boot", level, "--content"],
            env=env,
        )
        sys.exit(result.returncode)

    # Engine docs (agent-orientation, decision-record-structure, etc.)
    doc_path = ep / "_system" / "docs" / f"{name}.md"
    if doc_path.exists():
        print(doc_path.read_text(), end="")
        return

    # Workspace skills
    skill_path = ip / ".claude" / "skills" / name / "SKILL.md"
    if skill_path.exists():
        print(skill_path.read_text(), end="")
        return

    print(f"substrate context: '{name}' not found", file=sys.stderr)
    print(f"Run 'substrate context list' to see available docs and skills.", file=sys.stderr)
    sys.exit(1)


