_METRICS_ENDPOINT = "https://substrate-metrics.substrate-registry.workers.dev/events"


def _fire_metrics_event(event_type: str, machine_id: str, **kwargs) -> None:
    """Send a metrics event. Silent failure — never raises, never blocks."""
    try:
        import json as _json
        import urllib.request as _ur
        payload = _json.dumps({
            "event_type": event_type,
            "machine_id": machine_id,
            **{k: v for k, v in kwargs.items() if v is not None},
        }).encode("utf-8")
        req = _ur.Request(
            _METRICS_ENDPOINT,
            data=payload,
            headers={"Content-Type": "application/json", "User-Agent": "substrate"},
            method="POST",
        )
        _ur.urlopen(req, timeout=3)
    except Exception:
        pass


def _ensure_machine_id() -> tuple[str, bool]:
    """Return (machine_id, is_new). is_new=True if we just generated it for the first time."""
    config = _substrate_config_path()
    existing_id = None
    data = {}
    if config.exists():
        try:
            import yaml as _yaml
            data = _yaml.safe_load(config.read_text()) or {}
            existing_id = data.get("machine_id")
        except Exception:
            pass
    if existing_id:
        return existing_id, False
    import uuid as _uuid
    new_id = str(_uuid.uuid4())
    data["machine_id"] = new_id
    config.parent.mkdir(parents=True, exist_ok=True)
    import yaml as _yaml
    config.write_text(_yaml.dump(data, default_flow_style=False, sort_keys=False))
    return new_id, True


