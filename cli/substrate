def _get_schema_for_alias():
    """Load schema for alias collision checking."""
    ip = instance_path()
    ep = engine_path(ip)
    scripts_dir = str(ep / "_system" / "scripts")
    if scripts_dir not in sys.path:
        sys.path.insert(0, scripts_dir)
    from schema import load_schema as _ls
    return _ls(str(ip))


def _get_canonical_names(schema, kind: str) -> set:
    """Return all canonical names for the given kind."""
    if kind == "type":
        return set(schema.known_types)
    elif kind == "attribute":
        names = set()
        names.update(schema.attributes.get("attributes", {}).keys())
        names.update(schema.attributes.get("universal", {}).keys())
        for block_def in schema.attributes.get("blocks", {}).values():
            names.update(block_def.get("fields", {}).keys())
        names.update(schema.attributes.get("dimensions", {}).keys())
        return names
    elif kind == "relationship":
        return set(schema.relationship_names)
    return set()


def cmd_schema_alias(rest: list[str]) -> None:
    """substrate schema alias type|attribute|relationship CANONICAL ALIAS
       substrate schema alias check
    """
    if not rest or rest[0] in ("-h", "--help"):
        print("Usage: substrate schema alias type|attribute|relationship CANONICAL ALIAS")
        print("       substrate schema alias check")
        sys.exit(0)

    sub = rest[0]

    if sub == "check":
        try:
            schema = _get_schema_for_alias()
            overlay = _load_overlay()
            collisions = _check_alias_collisions(schema, overlay.get("aliases", {}))
            if not collisions:
                print(json.dumps({"status": "ok", "message": "No collisions found."}))
            else:
                result = []
                for c in collisions:
                    result.append({
                        "kind": c["kind"],
                        "alias": c["alias"],
                        "canonical": c["canonical"],
                        "collision_with": c["collision_with"],
                        "fix": f"substrate schema unalias {c['kind']} {c['canonical']}",
                    })
                print(json.dumps({"status": "collisions", "collisions": result}, indent=2))
        except Exception as exc:
            print(json.dumps({"error": str(exc)}))
            sys.exit(1)
        return

    if len(rest) < 3:
        print("Usage: substrate schema alias type|attribute|relationship CANONICAL ALIAS", file=sys.stderr)
        sys.exit(1)

    kind = sub
    canonical = rest[1]
    alias_target = rest[2]

    if kind not in ("type", "attribute", "relationship"):
        print(f"substrate schema alias: unknown kind '{kind}' — must be type, attribute, or relationship", file=sys.stderr)
        sys.exit(1)

    try:
        schema = _get_schema_for_alias()
    except Exception as exc:
        print(json.dumps({"error": f"Could not load schema: {exc}"}))
        sys.exit(1)

    # Validate canonical exists
    canonical_names = _get_canonical_names(schema, kind)
    if canonical not in canonical_names:
        print(json.dumps({"error": f"Canonical {kind} '{canonical}' not found in schema."}))
        sys.exit(1)

    # Load existing aliases
    overlay = _load_overlay()
    aliases = overlay.get("aliases", {})
    if not isinstance(aliases, dict):
        aliases = {}

    kind_key = kind + "s"  # type -> types, attribute -> attributes, relationship -> relationships
    kind_aliases = aliases.get(kind_key, {})
    if not isinstance(kind_aliases, dict):
        kind_aliases = {}

    # Collision check: alias target must not match any canonical name
    if alias_target in canonical_names:
        print(json.dumps({"error": f"Alias target '{alias_target}' conflicts with a canonical {kind} name."}))
        sys.exit(1)

    # Alias target must not already be used by a different canonical
    for existing_canonical, existing_alias in kind_aliases.items():
        if existing_alias == alias_target and existing_canonical != canonical:
            print(json.dumps({"error": f"Alias target '{alias_target}' is already used for {kind} '{existing_canonical}'."}))
            sys.exit(1)

    # Write
    kind_aliases[canonical] = alias_target
    aliases[kind_key] = kind_aliases
    overlay["aliases"] = aliases
    _save_overlay(overlay)

    print(json.dumps({"status": "ok", "kind": kind, "canonical": canonical, "alias": alias_target}))


def cmd_schema_unalias(rest: list[str]) -> None:
    """substrate schema unalias type|attribute|relationship CANONICAL"""
    if len(rest) < 2:
        print("Usage: substrate schema unalias type|attribute|relationship CANONICAL", file=sys.stderr)
        sys.exit(1)

    kind = rest[0]
    canonical = rest[1]

    if kind not in ("type", "attribute", "relationship"):
        print(f"substrate schema unalias: unknown kind '{kind}' — must be type, attribute, or relationship", file=sys.stderr)
        sys.exit(1)

    overlay = _load_overlay()
    aliases = overlay.get("aliases", {})
    if not isinstance(aliases, dict):
        aliases = {}

    kind_key = kind + "s"
    kind_aliases = aliases.get(kind_key, {})
    if not isinstance(kind_aliases, dict) or canonical not in kind_aliases:
        print(json.dumps({"error": f"No alias found for {kind} '{canonical}'."}))
        sys.exit(1)

    removed_alias = kind_aliases.pop(canonical)
    aliases[kind_key] = kind_aliases
    overlay["aliases"] = aliases
    _save_overlay(overlay)

    print(json.dumps({"status": "ok", "kind": kind, "canonical": canonical, "removed_alias": removed_alias}))


def cmd_schema_hide(rest: list[str]) -> None:
    """substrate schema hide type|attribute|relationship NAME"""
    if len(rest) < 2:
        print("Usage: substrate schema hide type|attribute|relationship NAME", file=sys.stderr)
        sys.exit(1)

    kind = rest[0]
    name = rest[1]

    if kind not in ("type", "attribute", "relationship"):
        print(f"substrate schema hide: unknown kind '{kind}' — must be type, attribute, or relationship", file=sys.stderr)
        sys.exit(1)

    overlay = _load_overlay()
    hidden = overlay.get("hidden", {})
    if not isinstance(hidden, dict):
        hidden = {}

    kind_key = kind + "s"
    kind_list = hidden.get(kind_key, [])
    if not isinstance(kind_list, list):
        kind_list = []

    if name not in kind_list:
        kind_list.append(name)
    hidden[kind_key] = kind_list
    overlay["hidden"] = hidden
    _save_overlay(overlay)

    print(json.dumps({"status": "ok", "kind": kind, "name": name, "hidden": True}))


