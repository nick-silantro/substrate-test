    env = {**os.environ, "SUBSTRATE_PATH": str(ip), "SUBSTRATE_ENGINE_PATH": str(ep)}
    s = ep / "_system" / "scripts" / "migrate-to-sqlite.py"
    if s.exists():
        subprocess.run(["python3", str(s)], env=env, check=False, capture_output=True)
        print(f"✓ Index rebuilt")




def cmd_channel(rest: list[str]) -> None:
    """Show or set the engine update channel (machine-wide, not per-instance)."""
    if not rest or rest[0] in ("-h", "--help"):
        channel = _read_update_channel()
        print(f"Update channel: {channel}")
        print(f"  main  — stable releases (default)")
        print(f"  dev   — beta/staging channel")
        print()
        print(f"Config: {_substrate_config_path()}")
        print(f"To change: substrate channel set <main|dev>")
        return

    if rest[0] == "set":
        if len(rest) < 2 or rest[1] not in ("main", "dev"):
            print("Usage: substrate channel set <main|dev>", file=sys.stderr)
            sys.exit(1)
        try:
            _set_update_channel(rest[1])
            print(f"✓ Update channel set to '{rest[1]}'")
            print(f"  Next `substrate update` will pull from the '{rest[1]}' branch.")
            print(f"  Config: {_substrate_config_path()}")
        except Exception as exc:
            print(f"Error: could not write {_substrate_config_path()} — {exc}", file=sys.stderr)
            sys.exit(1)
    else:
        print(f"substrate channel: unknown subcommand '{rest[0]}'", file=sys.stderr)
        print("Usage: substrate channel [set <main|dev>]", file=sys.stderr)
        sys.exit(1)


def cmd_version(_rest: list[str]) -> None:
    ep = engine_path()
    # Try to get git tag / commit
    version = "unknown"
    try:
        tag = subprocess.run(
            ["git", "-C", str(ep), "describe", "--tags", "--abbrev=0"],
            capture_output=True, text=True,
        )
        if tag.returncode == 0:
            version = tag.stdout.strip()
            # Also get short commit for precision
            commit = subprocess.run(
                ["git", "-C", str(ep), "rev-parse", "--short", "HEAD"],
                capture_output=True, text=True,
            )
            if commit.returncode == 0:
                version = f"{version} ({commit.stdout.strip()})"
    except FileNotFoundError:
        pass  # git not available
    print(f"substrate {version}")
    print(f"  engine:   {ep}")
    print(f"  instance: {instance_path()}")


